# Copy to .env and fill in. Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Run twice for two different values.
#
# JWT_SECRET must be at least 32 characters (64 hex chars from the command above).
# The lines below are placeholders only — replace both with real output from the command.

JWT_SECRET=replace_with_64_hex_chars_from_openssl_or_node_command_above
ENCRYPTION_KEY=replace_with_second_64_hex_run

PORT=5500
NODE_ENV=development

# Storage backend: 'json' (default, single-process) or 'supabase' (production).
# Switch to 'supabase' once you've applied schema/000_init.sql in your project.
MERIDIAN_STORE=json

# Optional: where the JSON store persists. Default: ./data/meridian-store.json
# MERIDIAN_STORE_PATH=/path/to/meridian-store.json

# Supabase (required for Google OAuth + production data persistence).
# See docs/SUPABASE_SETUP.md and docs/WEB_PUBLISH.md.
#   SUPABASE_URL                 - https://<project>.supabase.co
#   SUPABASE_ANON_KEY            - publishable/anon key (browser + token verify)
#   SUPABASE_SERVICE_ROLE_KEY    - secret key (server only, NEVER in browser)
#   SUPABASE_JWT_SECRET          - optional; legacy HS256 only (not key UUIDs)
