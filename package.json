{
  "name": "meridian-ai",
  "private": false,
  "version": "2.0.0",
  "description": "Meridian AI — LLM cost intelligence dashboard with Supabase + Render deploy",
  "scripts": {
    "build:css": "node ./node_modules/tailwindcss/lib/cli.js -i ./src/styles/input.css -o ./src/styles/meridian.bundle.css --minify",
    "build": "npm run build:css",
    "prestart": "npm run build:css",
    "start": "node server/index.js",
    "start:api": "node server/index.with-api.js",
    "dev": "npm run build:css && node server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "doctor": "node scripts/doctor.js",
    "seed:demo": "node scripts/seed-demo.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@babel/standalone": "^7.29.0",
    "@supabase/supabase-js": "^2.45.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.76",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "supertest": "^7.2.2",
    "vitest": "^2.1.9"
  }
}
